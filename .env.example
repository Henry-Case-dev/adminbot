# Telegram Bot Token (REQUIRED)
API_TOKEN=your_telegram_bot_token_here

# Database path (optional, default: local_database.db)
DB_PATH=local_database.db

# Media directory (optional, default: media)
MEDIA_BASE=media

# User IDs (optional, defaults below)
SLAVIK_USER_ID=479167456
KOSTIK_USER_ID=350803143
ALAN_USER_ID=138811255

# Alan reply interval — bot replies with random phrase every N messages (optional, default: 10)
ALAN_REPLY_INTERVAL=10

# Kostik reply probability — 0.0 to 1.0 (optional, default: 1.0 = reply to every message)
KOSTIK_REPLY_PROBABILITY=1.0

# Dead Page V2 — Repost-triggered (optional, defaults below)
DEAD_PAGE_SOURCE_CHANNEL_USERNAME=d_pages
DEAD_PAGE_SOURCE_CHANNEL_ID=0
DEAD_PAGE_RELAY_CHANNEL_ID=-1004228645624
DEAD_PAGE_CAPTION_MAX_CHARS=1024
DEAD_PAGE_COOLDOWN_SECONDS=0
DEAD_PAGE_POST_ON_JOIN=True
DEAD_PAGE_MAX_FORWARD_RETRIES=5

# GIF — send mp4 every N messages (optional, default: 5)
GIF_INTERVAL=5
GIF_PATH=media/slavic_chlen.mp4

# Dead page media directory (optional)
DEAD_PAGE_DIR=media/dead_page

# Alan greeting video (F7) — random video sent when Alan joins (optional, defaults below)
ALAN_USERNAME=@Alan_Z
ALAN_GREETING_DIR=media/leha_greeting
ALAN_GREETING_COOLDOWN=10

# Admin user ID for test commands (optional, default: 5885953495)
ADMIN_USER_ID=5885953495

# Better Stack Monitoring (optional — leave empty to disable)
SENTRY_DSN=your_sentry_dsn_here
LOGTAIL_SOURCE_TOKEN=your_logtail_source_token_here

# ── War Words Alert (F5v2 / Epic 10) ──
# Comma-separated Telegram channel IDs to monitor for reposts (like "ЧП Пермь", "Радар БПЛА")
WAR_CHANNEL_IDS=1654872411
# Comma-separated channel usernames (without @). Use this OR channel IDs, or both.
WAR_CHANNEL_USERNAMES=
# Comma-separated reply phrases (random choice). Empty = built-in defaults.
WAR_REPLIES=